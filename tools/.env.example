# Copy this file to .env and fill in the values from Terraform outputs.
# Run: cp .env.example .env

# --- Speech (enable_speech_deployment = true) ---
SPEECH_ENDPOINT=https://<speech-account-name>.cognitiveservices.azure.com/
SPEECH_REGION=eastus
SPEECH_RESOURCE_ID=/subscriptions/<subscription-id>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<speech-account-name>

# --- Language (enable_language_deployment = true) ---
LANGUAGE_ENDPOINT=https://<language-account-name>.cognitiveservices.azure.com/

# --- Translator (enable_translator_deployment = true) ---
# Use the custom-domain cognitiveservices.azure.com endpoint, not the global translator endpoint.
TRANSLATOR_ENDPOINT=https://<translator-account-name>.cognitiveservices.azure.com/
TRANSLATOR_REGION=eastus

# --- Document Intelligence (enable_document_intelligence_deployment = true) ---
DOCUMENT_INTELLIGENCE_ENDPOINT=https://<docintel-account-name>.cognitiveservices.azure.com/

# --- Search + RAG (enable_search_deployment = true) ---
SEARCH_ENDPOINT=https://<search-service-name>.search.windows.net
SEARCH_INDEX_NAME=

# Azure OpenAI endpoint and deployment for RAG (reuses the main Foundry account)
AZURE_OPENAI_ENDPOINT=https://<foundry-account-name>.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4-1-mini
